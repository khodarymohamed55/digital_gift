<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>هدية خاصة 💌</title>
    <style>
        body { background-color: #fce4ec; font-family: sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .container { background: white; padding: 30px; border-radius: 20px; text-align: center; box-shadow: 0 10px 25px rgba(0,0,0,0.1); width: 80%; }
        input { width: 80%; padding: 10px; margin: 20px 0; border: 2px solid #f8bbd0; border-radius: 10px; text-align: center; }
        button { background: #e91e63; color: white; border: none; padding: 10px 30px; border-radius: 10px; cursor: pointer; }
    </style>
</head>
<body>

    <div id="login" class="container">
        <h2>هدية خاصة 💌</h2>
        <p>أدخلي كلمة السر لفتح الظرف</p>
        <input type="password" id="passInput" placeholder="....">
        <br>
        <button onclick="checkPassword()">فتح الظرف</button>
    </div>

    <script>
        function checkPassword() {
            let pass = document.getElementById("passInput").value;
            if (pass === "2007") {
                alert("تم بنجاح!");
            } else {
                alert("كلمة السر خاطئة!");
            }
        }
    </script>
</body>
</html>
